# Rename to .env and fill with real values before running (DO NOT commit your real HF_TOKEN)
PORT=8080
HF_TOKEN=REPLACE_WITH_YOUR_HF_BEARER_TOKEN
CLIENT_API_KEY=change-me
ALLOWED_ORIGINS=*
RATE_LIMIT=60
CERT_DIR=/root/acme/caddy_v2ray-cert
SSL_CERT=/path/to/fullchain.pem
SSL_KEY=/path/to/key.pem
HTTPS_PORT=8443
